{
  "name": "birdgame",
  "version": "1.0.0",
  "description": "Browser 3D bird flying game with multiplayer",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/index.js",
    "start:legacy": "node server.js",
    "build": "node build.js",
    "build:prod": "node build.js --prod",
    "start:prod": "node dist/server.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e"
  },
  "dependencies": {
    "express": "^4.18.2",
    "three": "^0.182.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "@types/three": "^0.182.0",
    "@vitest/coverage-v8": "^1.0.0",
    "esbuild": "^0.20.2",
    "jsdom": "^23.0.0",
    "typescript": "^5.9.3",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
